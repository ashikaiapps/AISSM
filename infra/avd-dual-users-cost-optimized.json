{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "4664449270131454926"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for AVD resources."
      }
    },
    "workspaceName": {
      "type": "string",
      "defaultValue": "wksp-ashik-avd-centralindia",
      "metadata": {
        "description": "Workspace name."
      }
    },
    "arbeetHostPoolName": {
      "type": "string",
      "defaultValue": "hp-arbeet-dev",
      "metadata": {
        "description": "Host pool name for Arbeet."
      }
    },
    "nirajHostPoolName": {
      "type": "string",
      "defaultValue": "hp-niraj-gpu",
      "metadata": {
        "description": "Host pool name for Niraj."
      }
    },
    "arbeetAppGroupName": {
      "type": "string",
      "defaultValue": "dag-arbeet-dev",
      "metadata": {
        "description": "Desktop application group name for Arbeet."
      }
    },
    "nirajAppGroupName": {
      "type": "string",
      "defaultValue": "dag-niraj-gpu",
      "metadata": {
        "description": "Desktop application group name for Niraj."
      }
    },
    "scalingPlanName": {
      "type": "string",
      "defaultValue": "sp-avd-personal-costsafe",
      "metadata": {
        "description": "Scaling plan name shared by both personal host pools."
      }
    },
    "avdTimeZone": {
      "type": "string",
      "defaultValue": "Nepal Standard Time",
      "metadata": {
        "description": "Windows timezone for Nepal. Keep this as Nepal Standard Time."
      }
    },
    "arbeetUserObjectId": {
      "type": "string",
      "metadata": {
        "description": "Object ID of Arbeet user in Entra ID."
      }
    },
    "nirajUserObjectId": {
      "type": "string",
      "metadata": {
        "description": "Object ID of Niraj user in Entra ID."
      }
    },
    "avdPowerServicePrincipalObjectId": {
      "type": "string",
      "metadata": {
        "description": "Object ID of the AVD service principal that needs power management permissions for Start VM on Connect."
      }
    },
    "arbeetSessionHostVmNames": {
      "type": "array",
      "metadata": {
        "description": "VM names in Arbeet host pool. Personal pool should usually have one VM."
      }
    },
    "nirajSessionHostVmNames": {
      "type": "array",
      "metadata": {
        "description": "VM names in Niraj host pool. Personal pool should usually have one VM."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "workload": "avd",
        "env": "prod",
        "costProfile": "optimized"
      },
      "metadata": {
        "description": "Optional tags."
      }
    }
  },
  "variables": {
    "allSessionHostVmNames": "[concat(parameters('arbeetSessionHostVmNames'), parameters('nirajSessionHostVmNames'))]",
    "disconnectedTimeoutCommand": "powershell -ExecutionPolicy Bypass -EncodedCommand ",
    "desktopVirtualizationUserRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '1d336d2c-4ae8-42ef-9711-b3604ce3fc2c')]",
    "powerOnOffRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '40c5ff49-9181-41f8-ae61-143b0e78555e')]"
  },
  "resources": [
    {
      "type": "Microsoft.DesktopVirtualization/workspaces",
      "apiVersion": "2024-04-03",
      "name": "[parameters('workspaceName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "friendlyName": "[parameters('workspaceName')]",
        "description": "Workspace for Arbeet and Niraj personal desktops",
        "publicNetworkAccess": "Enabled",
        "applicationGroupReferences": [
          "[resourceId('Microsoft.DesktopVirtualization/applicationGroups', parameters('arbeetAppGroupName'))]",
          "[resourceId('Microsoft.DesktopVirtualization/applicationGroups', parameters('nirajAppGroupName'))]"
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.DesktopVirtualization/applicationGroups', parameters('arbeetAppGroupName'))]",
        "[resourceId('Microsoft.DesktopVirtualization/applicationGroups', parameters('nirajAppGroupName'))]"
      ]
    },
    {
      "type": "Microsoft.DesktopVirtualization/hostPools",
      "apiVersion": "2024-04-03",
      "name": "[parameters('arbeetHostPoolName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "hostPoolType": "Personal",
        "personalDesktopAssignmentType": "Automatic",
        "loadBalancerType": "Persistent",
        "preferredAppGroupType": "Desktop",
        "maxSessionLimit": 1,
        "startVMOnConnect": true,
        "validationEnvironment": false,
        "friendlyName": "Arbeet Dev Personal Host Pool",
        "description": "Personal host pool for Arbeet dev work",
        "customRdpProperty": "targetisaadjoined:i:1;enablerdsaadauth:i:1;redirectclipboard:i:1;redirectprinters:i:1;redirectcomports:i:0;redirectsmartcards:i:1;drivestoredirect:s:;audiocapturemode:i:1;audiomode:i:0;"
      }
    },
    {
      "type": "Microsoft.DesktopVirtualization/hostPools",
      "apiVersion": "2024-04-03",
      "name": "[parameters('nirajHostPoolName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "hostPoolType": "Personal",
        "personalDesktopAssignmentType": "Automatic",
        "loadBalancerType": "Persistent",
        "preferredAppGroupType": "Desktop",
        "maxSessionLimit": 1,
        "startVMOnConnect": true,
        "validationEnvironment": false,
        "friendlyName": "Niraj GPU Personal Host Pool",
        "description": "Personal host pool for Niraj Adobe workflows",
        "customRdpProperty": "targetisaadjoined:i:1;enablerdsaadauth:i:1;redirectclipboard:i:1;redirectprinters:i:1;redirectcomports:i:0;redirectsmartcards:i:1;drivestoredirect:s:;audiocapturemode:i:1;audiomode:i:0;"
      }
    },
    {
      "type": "Microsoft.DesktopVirtualization/applicationGroups",
      "apiVersion": "2024-04-03",
      "name": "[parameters('arbeetAppGroupName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "applicationGroupType": "Desktop",
        "hostPoolArmPath": "[resourceId('Microsoft.DesktopVirtualization/hostPools', parameters('arbeetHostPoolName'))]",
        "friendlyName": "Arbeet Desktop App Group",
        "description": "Desktop assignment for Arbeet",
        "showInFeed": true
      },
      "dependsOn": [
        "[resourceId('Microsoft.DesktopVirtualization/hostPools', parameters('arbeetHostPoolName'))]"
      ]
    },
    {
      "type": "Microsoft.DesktopVirtualization/applicationGroups",
      "apiVersion": "2024-04-03",
      "name": "[parameters('nirajAppGroupName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "applicationGroupType": "Desktop",
        "hostPoolArmPath": "[resourceId('Microsoft.DesktopVirtualization/hostPools', parameters('nirajHostPoolName'))]",
        "friendlyName": "Niraj Desktop App Group",
        "description": "Desktop assignment for Niraj",
        "showInFeed": true
      },
      "dependsOn": [
        "[resourceId('Microsoft.DesktopVirtualization/hostPools', parameters('nirajHostPoolName'))]"
      ]
    },
    {
      "type": "Microsoft.DesktopVirtualization/scalingPlans",
      "apiVersion": "2024-04-08-preview",
      "name": "[parameters('scalingPlanName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "friendlyName": "Personal desktop cost-optimized plan",
        "description": "24x7 start-on-connect + stop when no sessions",
        "timeZone": "[parameters('avdTimeZone')]",
        "hostPoolType": "Personal",
        "exclusionTag": "DoNotScale",
        "hostPoolReferences": [
          {
            "hostPoolArmPath": "[resourceId('Microsoft.DesktopVirtualization/hostPools', parameters('arbeetHostPoolName'))]",
            "scalingPlanEnabled": true
          },
          {
            "hostPoolArmPath": "[resourceId('Microsoft.DesktopVirtualization/hostPools', parameters('nirajHostPoolName'))]",
            "scalingPlanEnabled": true
          }
        ],
        "schedules": [
          {
            "name": "always-on-demand",
            "daysOfWeek": [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday",
              "Saturday",
              "Sunday"
            ],
            "rampUpStartTime": {
              "hour": 0,
              "minute": 0
            },
            "peakStartTime": {
              "hour": 0,
              "minute": 15
            },
            "rampDownStartTime": {
              "hour": 0,
              "minute": 30
            },
            "offPeakStartTime": {
              "hour": 23,
              "minute": 59
            },
            "rampUpLoadBalancingAlgorithm": "DepthFirst",
            "peakLoadBalancingAlgorithm": "DepthFirst",
            "rampDownLoadBalancingAlgorithm": "DepthFirst",
            "offPeakLoadBalancingAlgorithm": "DepthFirst",
            "rampUpMinimumHostsPct": 0,
            "rampUpCapacityThresholdPct": 1,
            "rampDownMinimumHostsPct": 0,
            "rampDownCapacityThresholdPct": 1,
            "rampDownStopHostsWhen": "ZeroSessions",
            "rampDownForceLogoffUsers": false,
            "rampDownWaitTimeMinutes": 30,
            "rampDownNotificationMessage": "Session host is set to auto-stop when no sessions remain. Please save your work before disconnecting."
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.DesktopVirtualization/hostPools', parameters('arbeetHostPoolName'))]",
        "[resourceId('Microsoft.DesktopVirtualization/hostPools', parameters('nirajHostPoolName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.DesktopVirtualization/applicationGroups', parameters('arbeetAppGroupName'))]",
      "name": "[guid(resourceId('Microsoft.DesktopVirtualization/applicationGroups', parameters('arbeetAppGroupName')), parameters('arbeetUserObjectId'), variables('desktopVirtualizationUserRoleDefinitionId'))]",
      "properties": {
        "principalId": "[parameters('arbeetUserObjectId')]",
        "roleDefinitionId": "[variables('desktopVirtualizationUserRoleDefinitionId')]",
        "principalType": "User"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DesktopVirtualization/applicationGroups', parameters('arbeetAppGroupName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.DesktopVirtualization/applicationGroups', parameters('nirajAppGroupName'))]",
      "name": "[guid(resourceId('Microsoft.DesktopVirtualization/applicationGroups', parameters('nirajAppGroupName')), parameters('nirajUserObjectId'), variables('desktopVirtualizationUserRoleDefinitionId'))]",
      "properties": {
        "principalId": "[parameters('nirajUserObjectId')]",
        "roleDefinitionId": "[variables('desktopVirtualizationUserRoleDefinitionId')]",
        "principalType": "User"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DesktopVirtualization/applicationGroups', parameters('nirajAppGroupName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceGroup().id, parameters('avdPowerServicePrincipalObjectId'), variables('powerOnOffRoleDefinitionId'))]",
      "properties": {
        "principalId": "[parameters('avdPowerServicePrincipalObjectId')]",
        "roleDefinitionId": "[variables('powerOnOffRoleDefinitionId')]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "copy": {
        "name": "sessionTimeoutPolicy",
        "count": "[length(variables('allSessionHostVmNames'))]"
      },
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}/avd-disconnected-timeout', variables('allSessionHostVmNames')[copyIndex()])]",
      "location": "[parameters('location')]",
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "CustomScriptExtension",
        "typeHandlerVersion": "1.10",
        "autoUpgradeMinorVersion": true,
        "settings": {},
        "protectedSettings": {
          "commandToExecute": "[variables('disconnectedTimeoutCommand')]"
        }
      }
    }
  ],
  "outputs": {
    "workspaceResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.DesktopVirtualization/workspaces', parameters('workspaceName'))]"
    },
    "arbeetHostPoolResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.DesktopVirtualization/hostPools', parameters('arbeetHostPoolName'))]"
    },
    "nirajHostPoolResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.DesktopVirtualization/hostPools', parameters('nirajHostPoolName'))]"
    },
    "scalingPlanResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.DesktopVirtualization/scalingPlans', parameters('scalingPlanName'))]"
    },
    "importantNote": {
      "type": "string",
      "value": "This template enforces Start VM on Connect + scaling plan stop on zero sessions and sets disconnected session timeout to 180 minutes."
    }
  }
}