{
  "name": "socialkeys-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:desktop": "concurrently \"npm:dev:api\" \"npm:dev:web\" \"npm run dev -w apps/desktop\"",
    "build": "npm run build --workspaces --if-present",
    "build:desktop": "npm run build:app -w apps/desktop",
    "dist:desktop": "npm run dist -w apps/desktop",
    "dist:desktop:win": "npm run dist:win -w apps/desktop",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate --config apps/api/drizzle.config.ts",
    "db:migrate": "tsx apps/api/src/db/migrate.ts",
    "db:studio": "drizzle-kit studio --config apps/api/drizzle.config.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
