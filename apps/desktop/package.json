{
  "name": "@socialkeys/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "SocialKeys.ai — Desktop app for cross-platform social media posting",
  "author": "AshikAI Apps",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build:main": "node scripts/build-main.js",
    "build:app": "node scripts/build-app.js",
    "dist": "npm run build:app && electron-builder",
    "dist:win": "npm run build:app && electron-builder --win",
    "dist:mac": "npm run build:app && electron-builder --mac",
    "dist:linux": "npm run build:app && electron-builder --linux"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.7"
  },
  "build": {
    "appId": "ai.socialkeys.desktop",
    "productName": "SocialKeys",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "web-dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../api/dist",
        "to": "api",
        "filter": ["**/*"]
      },
      {
        "from": "../api/node_modules",
        "to": "api-modules",
        "filter": ["**/*"]
      },
      {
        "from": "../api/drizzle",
        "to": "drizzle",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
